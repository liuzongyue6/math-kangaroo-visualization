# ========== Python 端忽略 ==========
# Python 字节码缓存
__pycache__/
*.pyc
*.py[cod]
*$py.class
# Python 虚拟环境
.venv/
venv/
env/
# pip 缓存
pip-wheel-metadata/
.pytest_cache/

# ========== 前端 React 端忽略 ==========
# 依赖包（绝对不要上传 node_modules）
node_modules/
# 打包产物
dist/
dist-ssr/
# 本地环境变量
.env
.env.*
# Vite 缓存
.vite/
# TypeScript 增量编译缓存
*.tsbuildinfo
# 冒烟验证截图（scripts/cdp-verify.mjs 产物）
kangaroo-renderer/verify-shots/

# ========== 编辑器/系统缓存 ==========
.vscode/
.idea/
.DS_Store
Thumbs.db

# ========== 可选：生成的题目JSON ==========
# 「只提交源码，产物本地生成」
# kangaroo-content/problems/
# kangaroo-renderer/public/problems/